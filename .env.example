# === REQUIRED SECRETS ===
# These variables must be set before running the application.
# The app will fail to start if they are missing.

JWT_SECRET=your-secret-key-change-in-production
MONGO_CLUSTER=cluster0.xxx.mongodb.net

# === OPTIONAL CONFIGURATION ===
# The following variables have defaults and can be omitted.

# MongoDB
MONGO_USERNAME=your_username
MONGO_PASSWORD=your_password
MONGO_DB=mindbridge

# Redis (Cloud)
REDIS_HOST=redis-xxx.cloud.redislabs.com
REDIS_PORT=12345
REDIS_USERNAME=default
REDIS_PASSWORD=your_redis_password

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=5000

# External Services
WEBSOCKET_URL=wss://agents.use.ai/agents/budget-agent
FILE_UPLOAD_URL=https://files.use.ai/upload
FILE_BASE_URL=https://files.use.ai
